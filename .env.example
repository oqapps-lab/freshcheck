# Copy to .env and fill with real values.
# Without these, the app falls back to mock fixtures in /mock.

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# Adapty public SDK key — required for subscriptions.
# Must be EXPO_PUBLIC_-prefixed to leak into the JS bundle (the SDK runs client-side).
EXPO_PUBLIC_ADAPTY_PUBLIC_KEY=public_live_xxxxxxxxxxxx

# AppsFlyer Dev Key — one per AppsFlyer account (not per app).
# Get from AppsFlyer dashboard → any app → App Settings → Dev Key.
# Until app is registered in AppsFlyer (via dashboard "My app is not available
# on the store yet"), the SDK will be a no-op even with the key set.
EXPO_PUBLIC_APPSFLYER_DEV_KEY=

# Apple App ID — numeric ID from App Store Connect, used by AppsFlyer iOS init.
# Empty until app is published. Format: 1234567890 (no "id" prefix).
EXPO_PUBLIC_APPLE_APP_ID=

# PostHog — feature flags + A/B + funnel analytics. Free tier 1M events/mo.
# Get from posthog.com → Project Settings → Project API Keys → "Project API Key".
# Host: https://us.i.posthog.com (US data residency) or https://eu.i.posthog.com (EU).
EXPO_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Server-side keys below — NO `EXPO_PUBLIC_` prefix (would leak into bundle).
# Used by Supabase CLI / Edge Functions / Mgmt API tooling, not the client.

# OpenAI API key — consumed by the `scan-image` Supabase Edge Function.
# Sync to Supabase secrets via: supabase secrets set OPENAI_API_KEY=sk-...
OPENAI_API_KEY=sk-...

# Supabase service role + project ref + DB password — Mgmt API / migrations / Edge Function deploy.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
