# Copy to .env and fill with real values.
# Without these, the app falls back to mock fixtures in /mock.

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# OpenAI key is consumed by the `scan-image` Supabase Edge Function,
# NOT the client. Do NOT prefix with EXPO_PUBLIC_. Set it with:
#   supabase secrets set OPENAI_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# Adapty public SDK key (required for subscriptions in Stage 4).
# EXPO_PUBLIC_ADAPTY_PUBLIC_KEY=public_live_...

SUPABASE_SERVICE_ROLE_KEY=
ADAPTY_PUBLIC_KEY=
