{
  "expo": {
    "name": "FreshCheck",
    "slug": "freshcheck",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "freshcheck",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#FDF9F0",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gazetastreet.freshcheck"
    },
    "android": {
      "package": "com.gazetastreet.freshcheck"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
