{
  "expo": {
    "name": "FreshCheck",
    "slug": "freshcheck",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "freshcheck",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#ECEFF4",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ECEFF4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gazetastreet.freshcheck",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "FreshCheck uses the camera to check the freshness of your food.",
        "NSPhotoLibraryUsageDescription": "FreshCheck can analyze photos from your library to check food freshness.",
        "NSUserTrackingUsageDescription": "FreshCheck uses your device identifier to measure ad performance and improve our recommendations.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.gazetastreet.freshcheck",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#15803d"
      },
      "permissions": ["android.permission.CAMERA", "android.permission.POST_NOTIFICATIONS"]
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FreshCheck uses the camera to check the freshness of your food."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#15803d"
        }
      ],
      ["react-native-adapty", { "replaceAndroidBackupConfig": true }],
      ["react-native-appsflyer", { "shouldUseStrictMode": true }],
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
