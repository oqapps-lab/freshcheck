{
  "expo": {
    "name": "FreshCheck",
    "slug": "freshcheck",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "freshcheck",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#ECEFF4",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ECEFF4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gazetastreet.freshcheck",
      "buildNumber": "43",
      "infoPlist": {
        "NSCameraUsageDescription": "FreshCheck uses the camera to check the freshness of your food.",
        "NSPhotoLibraryUsageDescription": "FreshCheck lets you pick a photo of your food from your library to check its freshness.",
        "NSUserTrackingUsageDescription": "FreshCheck uses your device identifier to measure ad performance and improve our recommendations.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gazetastreet.freshcheck",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#15803d"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-image",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          }
        }
      ],
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "FreshCheck uses the camera to check the freshness of your food."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FreshCheck lets you pick a photo of your food from your library to check its freshness."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#15803d"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "FreshCheck uses your device identifier to measure ad performance and improve our recommendations."
        }
      ],
      [
        "react-native-adapty",
        {
          "replaceAndroidBackupConfig": true
        }
      ],
      [
        "react-native-appsflyer",
        {
          "shouldUseStrictMode": true
        }
      ],
      "./plugins/with-modular-headers-fix.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ad2a528-532b-47f9-939b-46c508643ada"
      }
    },
    "owner": "gazetastreet"
  }
}